{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Cargo · PostgreSQL (CloudNativePG)",
  "uid": "cargo-postgres",
  "tags": ["cargo"],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(cnpg_collector_up, pod)",
        "query": { "query": "label_values(cnpg_collector_up, pod)", "refId": "A" },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "title": "Collector up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [], "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "cnpg_collector_up{pod=~\"$pod\"}", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "title": "Backends (connections)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (pod) (cnpg_backends_total{pod=~\"$pod\"})", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "title": "Database size",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "cnpg_pg_database_size_bytes{pod=~\"$pod\"}", "legendFormat": "{{pod}} / {{datname}}" }
      ]
    },
    {
      "title": "Commits / s",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (pod) (rate(cnpg_pg_stat_database_xact_commit{pod=~\"$pod\"}[5m]))", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "title": "Rollbacks / s",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (pod) (rate(cnpg_pg_stat_database_xact_rollback{pod=~\"$pod\"}[5m]))", "legendFormat": "{{pod}}" }
      ]
    }
  ]
}
