{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Cargo · JVM & Spring (Micrometer)",
  "uid": "cargo-jvm",
  "tags": ["cargo"],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(jvm_memory_used_bytes, pod)",
        "query": { "query": "label_values(jvm_memory_used_bytes, pod)", "refId": "A" },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "title": "Heap used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (pod) (jvm_memory_used_bytes{area=\"heap\", pod=~\"$pod\"})", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "title": "Non-heap used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (pod) (jvm_memory_used_bytes{area=\"nonheap\", pod=~\"$pod\"})", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "title": "GC pause rate (s/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (pod) (rate(jvm_gc_pause_seconds_sum{pod=~\"$pod\"}[5m]))", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "title": "Live threads",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "jvm_threads_live_threads{pod=~\"$pod\"}", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "title": "Process CPU usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage{pod=~\"$pod\"}", "legendFormat": "{{pod}}" }
      ]
    }
  ]
}
